{
  "name": "3d-print-tracker",
  "version": "3.0.0",
  "description": "Track your 3D printing jobs, parts and projects",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k -n WEB,ELECTRON -c cyan,yellow \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build:web": "vite build",
    "lint": "eslint main.js preload.js src/main/**/*.js src/lib/**/*.js src/**/*.jsx",
    "lint:fix": "eslint --fix main.js preload.js src/main/**/*.js src/lib/**/*.js src/**/*.jsx",
    "build": "npm run lint && npm run build:web && electron-builder --win"
  },
  "build": {
    "appId": "com.yourname.3dprinttracker",
    "productName": "3D Print Tracker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "main.js",
      "preload.js",
      "src/mobile.html",
      "src/main/**/*",
      "dist-web/**/*",
      "build-resources/**/*"
    ]
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.57.0",
    "vite": "^5.0.0"
  }
}
